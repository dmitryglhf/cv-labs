    {
      "id": "Kclp",
      "code_hash": "e03244d88b33bfc1351808cf0e52a4c5",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><span class=\"paragraph\"><strong>Fixed hyperparameters:</strong></span>\n<ul>\n<li>num_epochs: 50 (sufficient convergence for VOC dataset size)</li>\n<li>num_classes: 21 (20 objects + background)</li>\n<li>image_size: 512 (balance between detail and computational cost)</li>\n<li>pretrained: True (transfer learning accelerates convergence)</li>\n</ul>\n<span class=\"paragraph\"><strong>Tunable hyperparameters:</strong></span>\n<ul>\n<li>learning_rate: [1e-5, 1e-3]</li>\n<li>batch_size: [4, 8, 16]</li>\n<li>optimizer: [Adam, SGD]</li>\n<li>weight_decay: [1e-5, 1e-3]</li>\n</ul>\n<span class=\"paragraph\"><strong>Tuning method:</strong> Optuna with TPE sampler (10 trials)</span></span>"
          }
        }
      ],
      "console": []
